# URL base da API do backend.
# Local:           http://localhost:3001
# Produção (VPS):  https://api.bakaninha.seu-dominio.com
REACT_APP_API_URL=http://localhost:3001

# Rota da área administrativa (sem barra inicial).
# Trocar o valor regenera todas as URLs do admin. Mantém o painel
# longe de bots que varrem /admin, /wp-admin etc.
# Exemplo: gestao-bk-x7q9   → o painel abre em /gestao-bk-x7q9/login
REACT_APP_ADMIN_PATH=painel-bk-2026

# Número do WhatsApp do botão flutuante (DDI+DDD+número, só dígitos).
# Default já aponta pro número da Bakaninha.
REACT_APP_WHATSAPP_NUMBER=553838411604
